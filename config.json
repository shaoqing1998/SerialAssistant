{
    "serial": {
        "port": "",
        "baudrate": 115200,
        "bytesize": 8,
        "parity": "N",
        "stopbits": 1,
        "timeout": 0.1
    },
    "ui": {
        "window_width": 1100,
        "window_height": 650,
        "font_family": "Consolas",
        "font_size": 10,
        "max_log_lines": 5000
    },
    "send": {
        "hex_mode": false,
        "add_newline": true,
        "newline_type": "\\r\\n"
    },
    "logging": {
        "enabled": true,
        "root_dir": "",
        "file_format": ".log",
        "record_all_tabs": false,
        "selected_tabs": [
            "main",
            "filter-01"
        ]
    },
    "highlight": {
        "enabled": true,
        "default_fg": "#1e293b",
        "builtin_rules": {
            "timestamp": {
                "enabled": true,
                "case_sensitive": false,
                "fg": "#8c8c8c",
                "bg": null
            },
            "hex_addr": {
                "enabled": true,
                "case_sensitive": false,
                "fg": "#8a6cc5",
                "bg": null
            },
            "number": {
                "enabled": true,
                "case_sensitive": false,
                "fg": "#8a6cc5",
                "bg": null
            },
            "error": {
                "enabled": true,
                "case_sensitive": false,
                "fg": "#c0392b",
                "bg": "#fdecea"
            },
            "warn": {
                "enabled": true,
                "case_sensitive": false,
                "fg": "#b8860b",
                "bg": "#fef9e7"
            },
            "success": {
                "enabled": true,
                "case_sensitive": false,
                "fg": "#27864e",
                "bg": null
            },
            "disable": {
                "enabled": true,
                "case_sensitive": false,
                "fg": "#b05a30",
                "bg": null
            },
            "linux_log": {
                "enabled": true,
                "case_sensitive": false,
                "fg": "#3a8a8a",
                "bg": null
            },
            "bracket": {
                "enabled": false,
                "case_sensitive": false,
                "fg": "#5b8cc2",
                "bg": null
            }
        },
        "user_rules": []
    }
}